# ─── PACKPRO ERP — Environment Variables ─────────────────────────────────────
# Copy to .env.local for local dev. Set ALL in Vercel → Settings → Environment Variables.
# NEVER commit .env.local — it is gitignored.

# ─── DATABASE (Required) ──────────────────────────────────────────────────────
# POOLED connection string (Neon Pooled / PgBouncer) — used by Prisma Client for queries
# Neon: Dashboard → Connection Details → Connection string (Pooled mode)
# Local: postgresql://user:password@localhost:5432/packpro_erp
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# DIRECT (non-pooled) — required by prisma generate at Vercel build time AND for migrations.
# Neon: Dashboard → Connection Details → Connection string (Direct / no pooling)
# Local: set to the same value as DATABASE_URL (local Postgres has no pooler)
DIRECT_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# ─── AUTH (Required) ──────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET=replace-with-32-char-random-string

# NEXTAUTH_URL is auto-detected on Vercel. Only set for local dev:
# NEXTAUTH_URL=http://localhost:3000

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── Email / SMTP (Phase 1+) ──────────────────────────────────────────────────
# Transactional email for invoice delivery, payment reminders, user invitations.
# Recommended: Resend (resend.com), Postmark, or AWS SES.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=PACKPRO <noreply@packpro.site>

# ─── File Storage (Phase 1+) ──────────────────────────────────────────────────
# Recommended: Cloudflare R2 (S3-compatible, generous free tier) or AWS S3.
# Leave blank to fall back to local /public/uploads in development.
STORAGE_PROVIDER=          # "s3" | "r2" | "" (local)
STORAGE_BUCKET=
STORAGE_REGION=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_ENDPOINT=          # R2 only: https://[accountId].r2.cloudflarestorage.com

# ─── AI Services (Phase 4+) ───────────────────────────────────────────────────
# Powers invoice OCR, lead scoring, demand forecasting, natural language search.
ANTHROPIC_API_KEY=

# ─── Payment Gateway (Phase 5+) ───────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ─── WhatsApp Business API (Phase 5+) ────────────────────────────────────────
META_WA_TOKEN=
META_WA_PHONE_ID=
META_WA_WEBHOOK_VERIFY_TOKEN=

# ─── GST / E-Invoicing (Phase 2+) ────────────────────────────────────────────
# IRP (Invoice Registration Portal) credentials for e-invoicing above threshold.
GST_API_KEY=
IRP_USERNAME=
IRP_PASSWORD=

# ─── Monitoring (Recommended for production) ─────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
